from collections.abc import Callable
from typing import Any

import pandas as pd

class Dataset:
    def __len__(self) -> int: ...
    def __getitem__(self, key: int | str | slice) -> Any: ...
    @classmethod
    def from_pandas(cls, df: pd.DataFrame, **kwargs: Any) -> Dataset: ...
    def map(
        self,
        function: Callable[..., Any],
        remove_columns: list[str] | None = ...,
        desc: str | None = ...,
        **kwargs: Any,
    ) -> Dataset: ...
    def filter(self, function: Callable[..., bool], **kwargs: Any) -> Dataset: ...
    def shuffle(self, seed: int | None = ...) -> Dataset: ...
    def select(self, indices: range | list[int]) -> Dataset: ...
    def train_test_split(
        self, test_size: float = ..., seed: int | None = ..., **kwargs: Any,
    ) -> dict[str, Dataset]: ...
    @property
    def column_names(self) -> list[str]: ...
